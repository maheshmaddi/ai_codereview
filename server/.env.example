# OpenClaw Server ( migrated from OpenCode)
OPENCLAW_SERVER_URL=http://localhost:3000

# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Polling mode (alternative to webhooks — no workflow access needed)
# Set to true to auto-start polling when server starts
GITHUB_POLLING_ENABLED=false
# How often to check for new PRs (in seconds)
GITHUB_POLLING_INTERVAL_SECONDS=60

# Server
PORT=3001
# Web UI runs on port 3002 (OpenClaw uses 3000)
WEB_ORIGIN=http://localhost:3002

# Azure Key Vault (optional, for production secret retrieval)
AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net
